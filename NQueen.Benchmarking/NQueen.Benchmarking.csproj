		<ProjectReference Include="..\NQueen.Shared\NQueen.Shared.csproj" />
	</ItemGroup>

	<ItemGroup>
		<Folder Include="Artifacts\results\" />
	</ItemGroup>

	<ItemGroup>
	  <Reference Update="System.Collections.Immutable">
	    <Private>False</Private>
	  </Reference>
	</ItemGroup>

</Project>
