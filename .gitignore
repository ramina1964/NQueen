## Local .gitignore for NQueen repository
## Machine-wide .NET rules are in: C:\Users\ramin\.gitignore_global
## Register with: git config --global core.excludesfile "$env:USERPROFILE\.gitignore_global"

# -------------------------
# Build output
# -------------------------
[Bb]in/
[Oo]bj/

# -------------------------
# Visual Studio
# -------------------------
.vs/
*.user
*_wpftmp.csproj

# -------------------------
# BenchmarkDotNet
# -------------------------
BenchmarkDotNet.Artifacts/
**/Artifacts/

# -------------------------
# ASP.NET Scaffolding
# -------------------------
ScaffoldingReadMe.txt

# -------------------------
# StyleCop
# -------------------------
StyleCopReport.xml

# -------------------------
# Mono
# -------------------------
mono_crash.*

