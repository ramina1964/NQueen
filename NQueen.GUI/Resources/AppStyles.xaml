<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ******************** Spacing tokens (4px grid: 4 / 8 / 12) ********************  -->
    <!--  Single source of truth for layout spacing; reference these instead of literals.  -->
    <Thickness x:Key="PanelContentMargin">8</Thickness>
    <Thickness x:Key="FramePadding">4</Thickness>
    <Thickness x:Key="ButtonMargin">8</Thickness>
    <Thickness x:Key="FieldRowMargin">0,4</Thickness>
    <Thickness x:Key="LabelCellMargin">0,4,8,4</Thickness>
    <Thickness x:Key="InputCellMargin">0,4,0,4</Thickness>

    <!--  ******************** Typography tokens ********************  -->
    <!--  Caption / helper text size; reference instead of literal FontSize values.  -->
    <sys:Double x:Key="CaptionFontSize">11</sys:Double>

    <!--  ******************** Brush palette (single source of truth for colour) ********************  -->
    <!--  Reference these instead of literal colours so the theme can change in one place.  -->
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="Bisque" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="Black" />
    <SolidColorBrush x:Key="AccentBrush" Color="#95E3E2" />
    <SolidColorBrush x:Key="ProgressBrush" Color="Green" />
    <SolidColorBrush x:Key="SliderTrackBrush" Color="DarkOrchid" />

    <!--  Surface / text / selection brushes (exact previous literals, theme-neutral).  -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="White" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="Black" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="Gray" />
    <SolidColorBrush x:Key="TextSubtleBrush" Color="DarkSlateGray" />
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="Crimson" />

    <!--  Error/validation brushes (exact previous literals from LabelErrorStyle).  -->
    <SolidColorBrush x:Key="ErrorBorderBrush" Color="#FFF08A73" />
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#FFFFE3DF" />
    <SolidColorBrush x:Key="ErrorForegroundBrush" Color="Red" />

    <!--  ******************** Panel card (re-templated GroupBox) ********************  -->
    <!--  Flat, square "card" replacement for the GroupBox etched frame: a bold header band
          over a content row, with predictable sizing (no header notch) and content padding
          owned by the template via the Padding setter. Square top edge so the card aligns
          with the chessboard. Stays a GroupBox so Header still labels the group for UI
          Automation / screen readers.  -->
    <Style x:Key="PanelCardStyle" TargetType="{x:Type GroupBox}">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="{StaticResource PanelContentMargin}" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type GroupBox}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Header band with a bottom separator  -->
                            <Border
                                Grid.Row="0"
                                Padding="8,4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1"
                                SnapsToDevicePixels="True"
                                TextElement.FontWeight="Bold">
                                <ContentPresenter ContentSource="Header" />
                            </Border>

                            <!--  Content area; padding owned by the template  -->
                            <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ************************* Based on Label *************************  -->
    <Style x:Key="LabelStyle" TargetType="Label">
        <Setter Property="Height" Value="30" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="LabelErrorStyle" TargetType="{x:Type Label}">
        <Setter Property="Height" Value="30" />
        <Setter Property="BorderBrush" Value="{StaticResource ErrorBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource ErrorForegroundBrush}" />
        <Setter Property="Background" Value="{StaticResource ErrorBackgroundBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Label}">
                    <Border
                        Padding="{TemplateBinding Padding}"
                        HorizontalAlignment="Stretch"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="5"
                        SnapsToDevicePixels="true">
                        <TextBlock Text="{TemplateBinding Content}" TextWrapping="Wrap" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ************************ Based on TextBox ************************  -->
    <Style x:Key="TextBoxNumericalStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Height" Value="30" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!--  *********************** Based on ComboBox **********************  -->
    <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="30" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!--  *********************** Based on Slider **********************  -->
    <Style x:Key="SliderStyle" TargetType="Slider">
        <Setter Property="Height" Value="30" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource SliderTrackBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!--  ************************ Based on Button ************************  -->
    <Style x:Key="ButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="FontStyle" Value="Italic" />
        <Setter Property="Height" Value="25" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--  ************************ Based on ProgressBar ************************  -->
    <Style x:Key="ProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="30" />
        <Setter Property="Foreground" Value="{StaticResource ProgressBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FlowDirection" Value="LeftToRight" />
    </Style>

    </ResourceDictionary>
