<Window
    x:Class="NQueen.GUI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:NQueen.GUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:NQueen.GUI.Views"
    xmlns:viewmodel="clr-namespace:NQueen.GUI.ViewModels"
    Title="Solutions of NQueen Problem using Symmetry Pruned Backtracking with .NET 10.0"
    Width="1120"
    Height="780"
    MinWidth="760"
    MinHeight="560"
    Background="{StaticResource SurfaceBrush}"
    FontSize="14"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowState="Normal"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    mc:Ignorable="d">

    <!--  Viewbox scales the whole layout uniformly; board stays square, panels keep their ratios  -->
    <Viewbox Stretch="Uniform" SnapsToDevicePixels="True">
    <!--  Fixed design width so the Viewbox scale stays constant; content changes (e.g. selected-solution
          locations after Simulate) scroll within the layout instead of resizing the whole UI.  -->
    <Grid Width="1180" Margin="10,6,10,6" Background="{StaticResource SurfaceBrush}" HorizontalAlignment="Stretch" SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="40" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Top header row: spans the full canvas width and is independent of the body
              columns below, so a long selected-solution string scrolls inside the header
              (see the ScrollViewer in ActiveSolutionUserControl) instead of stretching the
              Auto board / solution-list columns and clipping the panels.  -->
        <Border x:Name="HeaderBorder"
            Grid.Row="0"
            Margin="0,0,0,4"
            Padding="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top"
            Background="Transparent">
            <view:ActiveSolutionUserControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        </Border>

        <!--  Body row: the five-column layout. Nested so the header above cannot inflate
              the Auto columns.  -->
        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftColumn" Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition x:Name="BoardColumn" Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!--  Left: Solution List  -->
            <view:ListOfSolutionsUserControl
                x:Name="solutionList"
                Grid.Column="0"
                Margin="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top" />

            <!--  Center: Chessboard  -->
            <ContentControl
                x:Name="chessboardPlaceholder"
                Grid.Column="2"
                Margin="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                MinWidth="200" />

            <!--  Right: Controls (fills board height; gaps distribute evenly) -->
            <Grid
                x:Name="controlColumn"
                Grid.Column="4"
                Grid.IsSharedSizeScope="True"
                Margin="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">

                <!--  Panels size to their natural height (Auto); the fixed 4px spacer rows keep a
                      constant gap between cards at all times — including while simulating, when the
                      old '*' space-between rows used to collapse to zero as the panels grew. The
                      bottom row with Height="*" fills remaining space to match chessboard height.  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="4" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="220" />
                </Grid.ColumnDefinitions>

                <ContentControl
                    x:Name="inputPanelPlaceHolder"
                    Grid.Row="0"
                    Grid.Column="0"
                    MinWidth="220"
                    HorizontalAlignment="Stretch" />

                <view:OutputPanelUserControl
                    Grid.Row="2"
                    Grid.Column="0"
                    MinWidth="220"
                    HorizontalAlignment="Stretch" />

                <ContentControl
                    x:Name="simulationPanelPlaceHolder"
                    Grid.Row="4"
                    Grid.Column="0"
                    MinWidth="220"
                    HorizontalAlignment="Stretch" />

                <view:AdvancedSettingsPanel
                    Grid.Row="6"
                    Grid.Column="0"
                    MinWidth="220"
                    HorizontalAlignment="Stretch" />
            </Grid>
        </Grid>
    </Grid>
    </Viewbox>
</Window>
