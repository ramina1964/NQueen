<Window
    x:Class="NQueen.GUI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:NQueen.GUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:NQueen.GUI.Views"
    xmlns:viewmodel="clr-namespace:NQueen.GUI.ViewModels"
    Title="Solutions of NQueen Problem with Backtracking - .NET 9.0"
    MinWidth="1200"
    MinHeight="1000"
    Background="White"
    FontSize="14"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowState="Normal"
    mc:Ignorable="d">

    <!--  Main grid layout for the window  -->
    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="140" />
            <ColumnDefinition Width="*" MaxWidth="1000" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!--  Top header row  -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Margin="0,0,0,10"
            Padding="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Background="WhiteSmoke"
            CornerRadius="8">
            <view:ActiveSolutionUserControl HorizontalAlignment="Stretch" VerticalAlignment="Center" />
        </Border>

        <!--  Left: Solution List  -->
        <view:ListOfSolutionsUserControl
            x:Name="solutionList"
            Grid.Row="1"
            Grid.Column="0"
            Margin="0,0,10,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top" />

        <!--  Center: Chessboard  -->
        <ContentControl
            x:Name="chessboardPlaceholder"
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,0,10,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Top" />

        <!--  Right: Controls  -->
        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Margin="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="Auto"
                    MinWidth="220"
                    SharedSizeGroup="RightCol" />
            </Grid.ColumnDefinitions>

            <ContentControl
                x:Name="inputPanelPlaceHolder"
                Grid.Row="0"
                Grid.Column="0"
                MinWidth="220"
                HorizontalAlignment="Stretch" />

            <view:OutputPanelUserControl
                Grid.Row="2"
                Grid.Column="0"
                MinWidth="220"
                HorizontalAlignment="Stretch" />

            <ContentControl
                x:Name="simulationPanelPlaceHolder"
                Grid.Row="4"
                Grid.Column="0"
                MinWidth="220"
                HorizontalAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>
