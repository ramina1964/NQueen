<UserControl
    x:Class="NQueen.GUI.Views.AdvancedSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    d:DesignWidth="260"
    d:DesignHeight="220"
    mc:Ignorable="d">

    <!-- Uses shared styles (TextBoxNumericalStyle, ComboBoxStyle, LabelStyle) for consistency -->
    <GroupBox Header="Performance &amp; Parallel Settings" Margin="0" Padding="0" Background="Bisque" BorderBrush="Black" BorderThickness="1">
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <!-- Use Parallel (auto-tuned, disabled for editing) -->
            <Label Grid.Row="0" Grid.Column="0" Content="Use Parallel (Auto)" Style="{StaticResource LabelStyle}" Margin="2 4 6 4" />
            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding UseParallel}" IsEnabled="False" HorizontalAlignment="Right" Margin="2 4" VerticalContentAlignment="Center" />

            <!-- Root Split Depth (auto-tuned, disabled) -->
            <Label Grid.Row="1" Grid.Column="0" Content="Root Split Depth (Auto)" Style="{StaticResource LabelStyle}" Margin="2 4 6 4" />
            <TextBox Grid.Row="1" Grid.Column="1" Width="60" Text="{Binding ParallelRootSplitDepth}" IsEnabled="False" HorizontalAlignment="Right" Style="{StaticResource TextBoxNumericalStyle}" />

            <!-- All Mode Storage -->
            <Label Grid.Row="2" Grid.Column="0" Content="All Mode Storage" Style="{StaticResource LabelStyle}" Margin="2 4 6 4" />
            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding EnumStorageModes}" SelectedItem="{Binding SelectedAllStorageMode}" HorizontalAlignment="Stretch" Style="{StaticResource ComboBoxStyle}" />

            <!-- Unique Mode Storage -->
            <Label Grid.Row="3" Grid.Column="0" Content="Unique Mode Storage" Style="{StaticResource LabelStyle}" Margin="2 4 6 4" />
            <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding EnumStorageModes}" SelectedItem="{Binding SelectedUniqueStorageMode}" HorizontalAlignment="Stretch" Style="{StaticResource ComboBoxStyle}" />

            <!-- Info Note -->
            <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="Parallel &amp; split depth auto-tuned by board size &amp; solution mode." FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="2 8 2 2" />
        </Grid>
    </GroupBox>
</UserControl>