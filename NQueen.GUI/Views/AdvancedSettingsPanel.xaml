<UserControl
    x:Class="NQueen.GUI.Views.AdvancedSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    d:DesignWidth="260"
    d:DesignHeight="260"
    mc:Ignorable="d">

    <!-- Uses shared styles (TextBoxNumericalStyle, ComboBoxStyle, LabelStyle) for consistency -->
    <GroupBox Header="Performance &amp; Parallel Settings" Margin="0" Padding="0" Background="Bisque" BorderBrush="Black" BorderThickness="1">
        <Grid Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>

            <!-- Row0: integrated checkbox + label (checkbox first) with adjusted left margins -->
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,4,0,4" VerticalAlignment="Center">
                <Label Content="Use Parallel Processing" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0" />
                <CheckBox IsChecked="{Binding UseParallel}" IsEnabled="False" VerticalAlignment="Center" Margin="0,0,6,0"/>
            </StackPanel>
            
            <!-- Row1: Root Split Depth -->
            <Label Grid.Row="1" Grid.Column="0" Content="Root Split Depth" Style="{StaticResource LabelStyle}" Margin="0,4,0,4" VerticalAlignment="Center" />
            <TextBox Grid.Row="1" Grid.Column="1" Width="100" Text="{Binding ParallelRootSplitDepth}" IsEnabled="False" HorizontalAlignment="Right" Style="{StaticResource TextBoxNumericalStyle}" Margin="0,4,0,4" VerticalAlignment="Center" />

            <!-- Row2: Storage Mode -->
            <Label Grid.Row="2" Grid.Column="0" Content="Solution Storage Mode" Style="{StaticResource LabelStyle}" Margin="0,4,0,4" VerticalAlignment="Center" />
            <ComboBox Grid.Row="2" Grid.Column="1" Width="100" ItemsSource="{Binding EnumStorageModes}" SelectedItem="{Binding SelectedStorageMode}" HorizontalAlignment="Right" Style="{StaticResource ComboBoxStyle}" IsEnabled="{Binding IsInInputMode}" Margin="0,4,0,4" VerticalAlignment="Center" />

            <!-- Row3: Half-board restriction toggle (All mode only) -->
            <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,4" VerticalAlignment="Center">
                <Label Content="Enable Half-Board (All mode)" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0" />
                <CheckBox IsChecked="{Binding EnableHalfBoardRestriction}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>

            <!-- Row4: Info Note -->
            <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Text="Auto-tuned settings. Storage Mode applies to current solution mode." FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,4" />
        </Grid>
    </GroupBox>
</UserControl>