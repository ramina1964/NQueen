<UserControl
    x:Class="NQueen.GUI.Views.AdvancedSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    d:DesignWidth="260"
    d:DesignHeight="180"
    mc:Ignorable="d">

    <GroupBox Header="Solver Settings" Style="{StaticResource PanelCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="Solution Storage Mode" Style="{StaticResource LabelStyle}" Margin="{StaticResource LabelCellMargin}" VerticalAlignment="Center" />
            <ComboBox Grid.Row="0" Grid.Column="1" Width="100" ItemsSource="{Binding EnumStorageModes}" SelectedItem="{Binding SelectedStorageMode}" HorizontalAlignment="Right" Style="{StaticResource ComboBoxStyle}" IsEnabled="{Binding CanChangeStorageMode}" Margin="{StaticResource InputCellMargin}" VerticalAlignment="Center" />

            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Text="Parallel auto-tuned; Half-board auto-enabled." FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,0" />
        </Grid>
    </GroupBox>
</UserControl>