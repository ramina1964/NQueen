<UserControl
    x:Class="NQueen.GUI.Views.OutputPanelUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    Background="Transparent"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <!-- GroupBox for Solution Summary -->
    <GroupBox Header="Solution Summary" Style="{StaticResource PanelCardStyle}">

        <!-- Content grid; padding owned by the card template -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Two columns: fixed-width label column ensures right-column alignment across all panels -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>

            <!-- Invisible width reference: the largest possible (ulong) count with space
                 separators. Its desired width forces col1 wide enough that real values never clip. -->
            <Label
                Grid.Row="0"
                Grid.Column="1"
                HorizontalContentAlignment="Right"
                Content="18 446 744 073 709 551 615"
                IsHitTestVisible="False"
                Style="{StaticResource LabelStyle}"
                Visibility="Hidden" />

            <!-- Board Size -->
            <Label
                Grid.Row="0"
                Grid.Column="0"
                Margin="{StaticResource LabelCellMargin}"
                Content="Board Size"
                Style="{StaticResource LabelStyle}" />

            <Label
                Grid.Row="0"
                Grid.Column="1"
                Margin="{StaticResource InputCellMargin}"
                HorizontalContentAlignment="Right"
                Content="{Binding BoardSize}"
                Style="{StaticResource LabelStyle}" />

            <!-- Result Title -->
            <Label
                Grid.Row="1"
                Grid.Column="0"
                Margin="{StaticResource LabelCellMargin}"
                Content="{Binding ResultLabel}"
                Style="{StaticResource LabelStyle}" />

            <Label
                Grid.Row="1"
                Grid.Column="1"
                Margin="{StaticResource InputCellMargin}"
                HorizontalContentAlignment="Right"
                Content="{Binding NoOfSolutions}"
                Style="{StaticResource LabelStyle}" />

            <!-- Elapsed Time -->
            <Label
                Grid.Row="2"
                Grid.Column="0"
                Margin="{StaticResource LabelCellMargin}"
                Content="Elapsed Time (sec)"
                Style="{StaticResource LabelStyle}" />

            <Label
                Grid.Row="2"
                Grid.Column="1"
                Margin="{StaticResource InputCellMargin}"
                HorizontalContentAlignment="Right"
                Content="{Binding ElapsedTimeInSec}"
                Style="{StaticResource LabelStyle}" />

            <!-- Memory Usage -->
            <Label
                Grid.Row="3"
                Grid.Column="0"
                Margin="{StaticResource LabelCellMargin}"
                Content="Memory Consumption (MB)"
                Style="{StaticResource LabelStyle}" />

            <Label
                Grid.Row="3"
                Grid.Column="1"
                Margin="{StaticResource InputCellMargin}"
                HorizontalContentAlignment="Right"
                Content="{Binding MemoryConsumption}"
                Style="{StaticResource LabelStyle}" />

            <!-- Save Button - placed in right column to avoid pushing grid layout -->
            <Button
                Grid.Row="4"
                Grid.Column="1"
                Width="140"
                Margin="{StaticResource ButtonMargin}"
                Command="{Binding SaveCommand}"
                Content="Save To File"
                Style="{StaticResource ButtonStyle}" />
        </Grid>
    </GroupBox>
</UserControl>
