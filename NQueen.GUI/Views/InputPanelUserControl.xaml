<UserControl
    x:Class="NQueen.GUI.Views.InputPanelUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:NQueen.GUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NQueen.GUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="Transparent"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:DisplayModeToEnabledConverter x:Key="DisplayModeToEnabledConverter" />
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter" />
    </UserControl.Resources>

    <!--  StackPanel for error and input group  -->
    <StackPanel>

        <!--  Error message outside the GroupBox  -->
        <Label
            Content="{Binding BoardSizeError}"
            Style="{StaticResource LabelErrorStyle}"
            Visibility="{Binding BoardSizeError, Converter={StaticResource StringNotEmptyToVisibilityConverter}}" />

        <!--  GroupBox for input controls  -->
        <GroupBox
            Margin="0"
            Padding="0"
            Background="Bisque"
            BorderBrush="Black"
            BorderThickness="1"
            Header="Input">

            <!--  Main content grid with consistent margin  -->
            <Grid Margin="{StaticResource PanelContentMargin}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Board Size  -->
                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="{StaticResource LabelCellMargin}"
                    Content="Board Size"
                    Style="{StaticResource LabelStyle}" />

                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Width="90"
                    MinWidth="120"
                    Margin="{StaticResource InputCellMargin}"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding IsInInputMode}"
                    Style="{StaticResource TextBoxNumericalStyle}"
                    Text="{Binding BoardSizeText, UpdateSourceTrigger=LostFocus, Mode=TwoWay, ValidatesOnDataErrors=True}" />

                <!--  Solution Mode  -->
                <Label
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="{StaticResource LabelCellMargin}"
                    Content="Solution Mode"
                    Style="{StaticResource LabelStyle}" />

                <ComboBox
                    Grid.Row="1"
                    Grid.Column="1"
                    Width="90"
                    MinWidth="120"
                    Margin="{StaticResource InputCellMargin}"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding IsInInputMode}"
                    ItemsSource="{Binding EnumSolutionModes, Mode=TwoWay}"
                    SelectedItem="{Binding SolutionMode, Mode=TwoWay}"
                    Style="{StaticResource ComboBoxStyle}" />

                <!--  Display Mode  -->
                <Label
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="{StaticResource LabelCellMargin}"
                    Content="Display Mode"
                    Style="{StaticResource LabelStyle}" />

                <ComboBox
                    x:Name="CmbDisplayMode"
                    Grid.Row="2"
                    Grid.Column="1"
                    Width="90"
                    MinWidth="120"
                    Margin="{StaticResource InputCellMargin}"
                    HorizontalAlignment="Right"
                    IsEnabled="{Binding IsInInputMode}"
                    ItemsSource="{Binding EnumDisplayModes, Mode=TwoWay}"
                    SelectedItem="{Binding DisplayMode, Mode=TwoWay}"
                    Style="{StaticResource ComboBoxStyle}" />

                <!--  Delay in Milisec  -->
                <Label
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="{StaticResource LabelCellMargin}"
                    Content="Delay in Milisec"
                    Style="{StaticResource LabelStyle}" />

                <Slider
                    x:Name="DelaySlider"
                    Grid.Row="3"
                    Grid.Column="1"
                    Width="90"
                    MinWidth="120"
                    Margin="{StaticResource InputCellMargin}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding DisplayMode, Converter={StaticResource DisplayModeToEnabledConverter}, ConverterParameter=Visualize}"
                    Maximum="3000"
                    Minimum="10"
                    Style="{StaticResource SliderStyle}"
                    Value="{Binding DelayInMilliseconds, Mode=TwoWay}" />

                <!--  Delay value text  -->
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="1"
                    Margin="0,0,5,2"
                    HorizontalAlignment="Right"
                    Foreground="DarkSlateGray"
                    FontSize="11"
                    Text="{Binding DelayInMilliseconds}" />
            </Grid>
        </GroupBox>
    </StackPanel>
</UserControl>
