<UserControl
    x:Class="NQueen.GUI.Views.InputPanelUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:NQueen.GUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NQueen.GUI.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:NQueen.GUI.Utils"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    DataContext="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel>
        <!--  Error Message TextBlock  -->
        <TextBlock
            Margin="0,0,0,10"
            Foreground="Red"
            Text="{Binding InputViewModel.ErrorMessage}"
            Visibility="{Binding InputViewModel.IsErrorVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
            AutomationProperties.Name="errorMessageTextBlock" />

        <GroupBox
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Left"
            VerticalContentAlignment="Stretch"
            Background="Bisque"
            BorderBrush="Black"
            BorderThickness="1"
            Header="Input"
            AutomationProperties.Name="inputGroupBox">

            <Grid
                Margin="5"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="5,2"
                    Content="Board Size"
                    Style="{StaticResource LabelStyle}"
                    AutomationProperties.Name="boardSizeLabel" />

                <TextBox
                    x:Name="txtBoardSize"
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="5,2"
                    AutomationProperties.Name="boardSizeTextBox"
                    IsEnabled="{Binding IsInInputMode}"
                    LostFocus="TxtBoardSize_LostFocus"
                    HorizontalContentAlignment="Right"
                    VerticalContentAlignment="Center"
                    Text="{Binding BoardSize, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource BoardSizeConverter}}"
                    TabIndex="0" />

                <Label
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="5,2"
                    Content="Solution Mode"
                    Style="{StaticResource LabelStyle}"
                    AutomationProperties.Name="solutionModeLabel" />

                <ComboBox
                    x:Name="cmbSolutionMode"
                    Grid.Row="1"
                    Grid.Column="1"
                    Height="{x:Static utils:Dimensions.ComboBoxHeight}"
                    Margin="5,2"
                    AutomationProperties.Name="solutionModeComboBox"
                    IsEnabled="{Binding IsInInputMode}"
                    ItemsSource="{Binding SolutionModeList, Mode=TwoWay}"
                    SelectedItem="{Binding SolutionMode}"
                    Style="{StaticResource ComboBoxStyle}"
                    TabIndex="1" />

                <Label
                    Grid.Row="2"
                    Grid.Column="0"
                    Margin="5,2"
                    Content="Display Mode"
                    Style="{StaticResource LabelStyle}"
                    AutomationProperties.Name="displayModeLabel" />

                <ComboBox
                    x:Name="cmbDisplayMode"
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="{x:Static utils:Dimensions.ComboBoxHeight}"
                    Margin="5,2"
                    AutomationProperties.Name="displayModeComboBox"
                    IsEnabled="{Binding IsInInputMode}"
                    ItemsSource="{Binding DisplayModeList, Mode=TwoWay}"
                    SelectedItem="{Binding DisplayMode}"
                    Style="{StaticResource ComboBoxStyle}"
                    TabIndex="2" />

                <Label
                    Grid.Row="3"
                    Grid.Column="0"
                    Margin="5,2"
                    Content="Delay in Milisec"
                    Style="{StaticResource LabelStyle}"
                    AutomationProperties.Name="delayInMillisecondsLabel" />

                <Slider
                    x:Name="sldDelayInMilliseconds"
                    Grid.Row="3"
                    Grid.Column="1"
                    Height="25"
                    Margin="5"
                    AutomationProperties.Name="delayInMillisecondsSlider"
                    IsEnabled="{Binding IsVisualized}"
                    Maximum="3000"
                    Minimum="10"
                    Style="{StaticResource SliderStyle}"
                    Value="{Binding DelayInMilliseconds}"
                    TabIndex="3" />
            </Grid>
        </GroupBox>
    </StackPanel>
</UserControl>
