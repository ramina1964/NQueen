<UserControl
    x:Class="NQueen.GUI.Views.ChessboardUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:NQueen.GUI.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    xmlns:utils="clr-namespace:NQueen.Kernel.Utilities;assembly=NQueen.Kernel"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    mc:Ignorable="d"
    Name="ChessboardControl">

    <UserControl.Resources>
        <local:NullImageConverter x:Key="NullImageConverter" />
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ItemsControl ItemsSource="{Binding Chessboard.Squares}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="{Binding Chessboard.BoardSize}" Columns="{Binding Chessboard.BoardSize}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border
                        Width="{Binding DataContext.Chessboard.SquareSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Height="{Binding DataContext.Chessboard.SquareSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Background="{Binding Color}"
                        Name="ChessboardSquareBorder">
                        <Image
                            Width="{Binding DataContext.Chessboard.SquareSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Height="{Binding DataContext.Chessboard.SquareSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Source="{Binding ImagePath, Converter={StaticResource NullImageConverter}}"
                            Name="ChessboardSquareImage" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
