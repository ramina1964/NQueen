<UserControl
    x:Class="NQueen.GUI.Views.ChessboardUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:NQueen.GUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:NullImageConverter x:Key="NullImageConverter" />
    </UserControl.Resources>

    <!--  Border for visual grouping and margin  -->
    <Border
        Margin="2"
        Padding="0"
        Background="White"
        BorderBrush="Black"
        BorderThickness="1">

        <!--  Grid for content alignment  -->
        <Grid
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <ItemsControl ItemsSource="{Binding ChessboardVm.Squares}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding BoardSize}" Rows="{Binding BoardSize}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="{Binding Color}">
                            <Image
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Source="{Binding ImagePath, Converter={StaticResource NullImageConverter}}"
                                Stretch="Uniform" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                
            </ItemsControl>
        </Grid>
    </Border>
</UserControl>
