<UserControl
    x:Class="NQueen.GUI.Views.SolutionSummaryPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    Background="Transparent"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <!-- GroupBox for Solution Summary -->
    <GroupBox Header="Solution Summary" Style="{StaticResource PanelCardStyle}">

        <!-- Content grid; padding owned by the card template -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Two columns: fixed-width label column ensures right-column alignment across all panels -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="185" />
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <!-- Result Title -->
            <Label
                Grid.Row="0"
                Grid.Column="0"
                Margin="{StaticResource LabelCellMargin}"
                Content="{Binding ResultLabel}"
                Style="{StaticResource LabelStyle}" />

            <Label
                Grid.Row="0"
                Grid.Column="1"
                Margin="{StaticResource InputCellMargin}"
                HorizontalContentAlignment="Right"
                Content="{Binding NoOfSolutions}"
                Style="{StaticResource LabelStyle}" />

            <!-- Elapsed Time -->
            <Label
                Grid.Row="1"
                Grid.Column="0"
                Margin="{StaticResource LabelCellMargin}"
                Content="Elapsed Time (sec)"
                Style="{StaticResource LabelStyle}" />

            <Label
                Grid.Row="1"
                Grid.Column="1"
                Margin="{StaticResource InputCellMargin}"
                HorizontalContentAlignment="Right"
                Content="{Binding ElapsedTimeInSec}"
                Style="{StaticResource LabelStyle}" />

            <!-- Memory Usage -->
            <Label
                Grid.Row="2"
                Grid.Column="0"
                Margin="{StaticResource LabelCellMargin}"
                Content="Memory Usage (MB)"
                Style="{StaticResource LabelStyle}" />

            <Label
                Grid.Row="2"
                Grid.Column="1"
                Margin="{StaticResource InputCellMargin}"
                HorizontalContentAlignment="Right"
                Content="{Binding MemoryConsumption}"
                Style="{StaticResource LabelStyle}" />

<!-- Save Button - centered across both columns, fixed width to match other buttons -->
<Button
    Grid.Row="3"
    Grid.Column="0"
    Grid.ColumnSpan="2"
    Width="120"
    HorizontalAlignment="Center"
    Margin="{StaticResource ButtonMargin}"
    Command="{Binding SaveCommand}"
    Content="Save To File"
    Style="{StaticResource ButtonStyle}" />
        </Grid>
    </GroupBox>
</UserControl>
