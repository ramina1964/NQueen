<UserControl
    x:Class="NQueen.GUI.Views.SimulationPanelUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <GroupBox
        Grid.Row="2"
        MinHeight="100"
        Margin="0,2,0,0"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="Bisque"
        BorderBrush="Black"
        BorderThickness="1"
        Header="Simulation">

        <Grid Margin="10,3,10,3">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Row="0"
                Grid.Column="0"
                Margin="5"
                Command="{Binding CancelCommand, UpdateSourceTrigger=PropertyChanged}"
                Content="Cancel"
                Style="{StaticResource ButtonStyle}" />

            <Button
                Grid.Row="0"
                Grid.Column="2"
                Margin="5"
                Command="{Binding SimulateCommand, UpdateSourceTrigger=PropertyChanged}"
                Content="Simulate"
                IsDefault="True"
                Style="{StaticResource ButtonStyle}" />

            <!--  ProgressBar with overlayed Label  -->
            <Grid
                Grid.Row="1"
                Grid.ColumnSpan="3"
                Height="35"
                Margin="0,2">
                <ProgressBar
                    Name="ProgressBar"
                    IsIndeterminate="{Binding IsSingleRunning}"
                    Maximum="1"
                    Minimum="0"
                    Style="{StaticResource ProgressBarStyle}"
                    Visibility="{Binding ProgressVisibility}"
                    Value="{Binding ProgressValue}" />
                <Label
                    Name="ProgressLabelStyle"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="{Binding ProgressLabel}"
                    Style="{StaticResource LabelStyle}"
                    Visibility="{Binding ProgressLabelVisibility}" />
            </Grid>
        </Grid>
    </GroupBox>
</UserControl>
