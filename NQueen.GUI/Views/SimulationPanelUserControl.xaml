<UserControl
    x:Class="NQueen.GUI.Views.SimulationPanelUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:NQueen.GUI.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="Transparent"
    mc:Ignorable="d">

    <!--  GroupBox for simulation controls  -->
    <GroupBox
        MinHeight="100"
        Margin="0"
        Padding="0"
        Background="Bisque"
        BorderBrush="Black"
        BorderThickness="1"
        Header="Simulation">

        <!--  Main content grid with consistent margin  -->
        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Margin="10,5"
                    Command="{Binding CancelCommand}"
                    Content="Cancel"
                    Style="{StaticResource ButtonStyle}" />
                <Button
                    Margin="10,5"
                    Command="{Binding SimulateCommand}"
                    Content="Simulate"
                    IsDefault="True"
                    Style="{StaticResource ButtonStyle}" />
            </StackPanel>

            <!--  ProgressBar with overlayed Label  -->
            <Grid
                Grid.Row="1"
                Margin="0,2">

                <ProgressBar
                    Name="ProgressBar"
                    IsIndeterminate="{Binding IsSingleRunning}"
                    Minimum="0"
                    Maximum="100"
                    Style="{StaticResource ProgressBarStyle}"
                    Visibility="{Binding ProgressVisibility}"
                    Value="{Binding ProgressPercent, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Label still bound to string label -->
                <Label
                    Name="ProgressLabelStyle"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Content="{Binding ProgressLabel}"
                    Style="{StaticResource LabelStyle}"
                    Visibility="{Binding ProgressLabelVisibility}" />
            </Grid>
        </Grid>
    </GroupBox>
</UserControl>
